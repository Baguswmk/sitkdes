// @ts-nocheck
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}


datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN_DESA
  OPERATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
}

enum JenisTanah {
  TANAH_KAS
  PELUNGGUH
  PENGAREM_AREM
  LAINNYA
}

enum KategoriPenggunaan {
  PERTANIAN
  NON_PERTANIAN
}

enum StatusData {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AttachmentType {
  ALAS_HAK
  FOTO
  PETA_PDF
  DOKUMEN_LAIN
}

// ============================================
// AUTH & USER MANAGEMENT
// ============================================

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  username String     @unique
  name     String
  passwordHash String
  role     UserRole   @default(OPERATOR)
  status   UserStatus @default(ACTIVE)

  // Password Management
  passwordChangedAt   DateTime @default(now())
  passwordExpired     Boolean  @default(false)
  mustChangePassword  Boolean  @default(true)
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  // Audit
  lastLoginAt DateTime?
  lastLoginIp String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  createdBy   User?     @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]   @relation("UserCreatedBy")

  // Relations
  sessions        Session[]
  passwordHistory PasswordHistory[]
  passwordResets  PasswordReset[]
  activityLogs    ActivityLog[]
  tkdCreated      TanahKasDesa[] @relation("TkdCreatedBy")
  tkdUpdated      TanahKasDesa[] @relation("TkdUpdatedBy")
  tkdApproved     TanahKasDesa[] @relation("TkdApprovedBy")

  @@index([email])
  @@index([username])
  @@index([role, status])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

// ============================================
// MASTER DATA
// ============================================

model Padukuhan {
  id        String  @id @default(cuid())
  nama      String  @unique
  kode      String? @unique
  deskripsi String?
  urutan    Int     @default(0)
  isActive  Boolean @default(true)

  // Geometry boundary (optional, for future use)
  boundary Unsupported("geometry(MultiPolygon, 4326)")?
  centroid Unsupported("geometry(Point, 4326)")?

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tanahKas  TanahKasDesa[]

  @@index([nama])
  @@index([isActive])
}

// ============================================
// CORE: TANAH KAS DESA
// ============================================

model TanahKasDesa {
  id String @id @default(cuid())

  // Identitas
  kode      String? @unique
  nub       String? @unique // Nomor Urut Bangunan, e.g. "0001" — set via DB sequence
  nama      String
  deskripsi String?

  // Klasifikasi
  jenisTanah         JenisTanah
  kategoriPenggunaan KategoriPenggunaan
  penggunaan         String
  pemanfaatan        String?

  // Lokasi
  padukuhanId String
  padukuhan   Padukuhan @relation(fields: [padukuhanId], references: [id])
  alamat      String?

  // Geometry (PostGIS) — stored as raw WKB, handled via $queryRaw
  geometry Unsupported("geometry(Geometry, 4326)")
  centroid Unsupported("geometry(Point, 4326)")?
  luasM2   Float
  luasHa   Float

  // Status & Legal (SENSITIVE)
  status            StatusData @default(DRAFT)
  statusKepemilikan String     @default("Tanah Kalurahan")
  alasHak           String? // SENSITIVE
  nomorSertifikat   String? // SENSITIVE

  // Approval Workflow
  submittedAt   DateTime?
  submittedById String?
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?     @relation("TkdApprovedBy", fields: [approvedById], references: [id])
  rejectionReason String?

  // Audit
  createdAt   DateTime  @default(now())
  createdById String
  createdBy   User      @relation("TkdCreatedBy", fields: [createdById], references: [id])
  updatedAt   DateTime  @updatedAt
  updatedById String?
  updatedBy   User?     @relation("TkdUpdatedBy", fields: [updatedById], references: [id])

  // Soft delete
  deletedAt DateTime?

  // Relations
  attachments Attachment[]
  history     TanahKasHistory[]

  @@index([nub])
  @@index([padukuhanId])
  @@index([jenisTanah])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  // Spatial GIST index created via manual migration
}

model TanahKasHistory {
  id         String       @id @default(cuid())
  tanahKasId String
  tanahKas   TanahKasDesa @relation(fields: [tanahKasId], references: [id], onDelete: Cascade)

  action        String // CREATE, UPDATE, DELETE, APPROVE, REJECT, SUBMIT
  changedFields Json // { field: { old: x, new: y } }
  snapshot      Json // Full snapshot of record at this point

  performedById String
  performedAt   DateTime @default(now())
  notes         String?

  @@index([tanahKasId, performedAt])
}

// ============================================
// FILE & ATTACHMENT
// ============================================

model Attachment {
  id         String         @id @default(cuid())
  tanahKasId String
  tanahKas   TanahKasDesa   @relation(fields: [tanahKasId], references: [id], onDelete: Cascade)

  type        AttachmentType
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  isSensitive Boolean        @default(false)

  uploadedById String
  uploadedAt   DateTime @default(now())

  @@index([tanahKasId])
}

// ============================================
// AUDIT LOG (System-wide)
// ============================================

model ActivityLog {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      String // login, logout, create_tkd, update_user, etc.
  entityType  String? // User, TanahKasDesa, etc.
  entityId    String?
  description String
  metadata    Json?

  ipAddress String?
  userAgent String?

  performedAt DateTime @default(now())

  @@index([userId, performedAt])
  @@index([entityType, entityId])
  @@index([action])
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model SystemConfig {
  id          String  @id @default(cuid())
  key         String  @unique
  value       Json
  description String?
  category    String  @default("general")

  updatedAt   DateTime @updatedAt
  updatedById String?

  @@index([category])
}
